{
  "openapi": "3.0.3",
  "info": {
    "title": "InternFlow API",
    "description": "Production-ready Internship & Recruitment Platform API Specification",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/api",
      "description": "Production API base URL"
    }
  ],
  "paths": {
    "/auth/login": {
      "post": {
        "summary": "Authenticate User",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string", "minLength": 6 }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Successfully authenticated, JWT cookie set" },
          "400": { "description": "Validation error" },
          "401": { "description": "Invalid credentials" }
        }
      }
    },
    "/auth/register": {
      "post": {
        "summary": "Register New Student or Company",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "name", "password", "role"],
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "name": { "type": "string" },
                  "password": { "type": "string", "minLength": 8 },
                  "role": { "type": "string", "enum": ["STUDENT", "COMPANY"] }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "User created" },
          "400": { "description": "Validation error or email in use" }
        }
      }
    },
    "/internships": {
      "get": {
        "summary": "List all internships (Public)",
        "parameters": [
          { "name": "search", "in": "query", "schema": { "type": "string" } },
          { "name": "type", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Array of internship objects with company details" }
        }
      },
      "post": {
        "summary": "Create internship posting (Company Only)",
        "responses": {
          "201": { "description": "Internship created" },
          "401": { "description": "Unauthenticated" },
          "403": { "description": "Forbidden" }
        }
      }
    },
    "/students/apply/{id}": {
      "post": {
        "summary": "Apply for an internship (Student Only)",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "201": { "description": "Application submitted" },
          "400": { "description": "Already applied or profile incomplete" },
          "403": { "description": "Forbidden (non-student)" }
        }
      }
    },
    "/applications/{id}/status": {
      "patch": {
        "summary": "Update applicant status (Company Only)",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["status"],
                "properties": {
                  "status": { "type": "string", "enum": ["PENDING", "ACCEPTED", "REJECTED"] }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Status updated" },
          "403": { "description": "Forbidden" }
        }
      }
    }
  }
}
